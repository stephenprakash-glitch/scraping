PORT=3000
NODE_ENV=development

# Optional: same value as Postman "Cookie" header for seats.aero (do not commit real values).
# SEATS_COOKIE=

# Optional: use Puppeteer to open /search in Chromium and collect cookies (slow; requires npm install).
# SEATS_PUPPETEER=true
# If you see "Could not find Chrome": run `npm run puppeteer:install` OR set:
# SEATS_USE_SYSTEM_CHROME=true

# Warm up session via GET /_api/vuerefdata before search_partial (default on). Set false to skip.
# SEATS_VUEREFDATA=false

